{
  "builds": [
    {
      "src": "artifacts/roadintel/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/artifacts/roadintel/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/artifacts/roadintel/dist/index.html"
    }
  ]
}